# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/platetrack?retryWrites=true&w=majority

# Server
PORT=5000

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Gmail SMTP (use a 16-character Gmail "App Password", not your normal Gmail password)
# Create one at https://myaccount.google.com/apppasswords (requires 2-Step Verification enabled)
GMAIL_USER=yourofficialaccount@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Used in outgoing email templates
APP_NAME=PlateTrack
